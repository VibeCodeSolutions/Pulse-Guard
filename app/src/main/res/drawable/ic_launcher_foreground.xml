<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground for Pulse Guard.

  Artwork: white heart shape centred in the 72 × 72 dp safe zone, overlaid with
  a white ECG pulse line at the lower third of the heart.

  All paths are contained within the 18–90 safe-zone boundary so no artwork is
  clipped by circular or squircle launcher masks.

  Viewport:   108 × 108
  Safe zone:  x ∈ [18, 90], y ∈ [18, 90]  (centre = 54, 54)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Heart shape.
      Bezier-curve heart centred at (54, 50) fitting inside the safe zone.
      Two upper lobes meet at the top-centre; the cusp points downward to (54, 74).
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M54,72
          C42,64 22,54 22,40
          C22,30 30,22 38,26
          C44,29 50,36 54,42
          C58,36 64,29 70,26
          C78,22 86,30 86,40
          C86,54 66,64 54,72 Z" />

    <!--
      ECG pulse line.
      Rendered as a white stroke over the lower portion of the heart.
      The baseline sits at y = 58; the QRS spike rises to y = 44 and dips to y = 68.
      strokeWidth = 3 provides good legibility at all launcher sizes.
    -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="
          M24,58
          L36,58
          L40,50
          L44,66
          L48,54
          L52,58
          L56,58
          L60,52
          L64,64
          L68,58
          L84,58" />
</vector>
