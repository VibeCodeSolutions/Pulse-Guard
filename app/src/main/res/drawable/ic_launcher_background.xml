<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon background for Pulse Guard.
  Deep medical-red base with a subtle lighter radial highlight in the top-right
  quadrant to give visual depth without requiring a gradient drawable.

  Safe zone: the inner 72 × 72 dp (from 18 to 90 in the 108 × 108 viewport)
  is guaranteed to be visible regardless of the launcher's clipping mask.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Solid deep-red base -->
    <path
        android:fillColor="#B71C1C"
        android:pathData="M0,0h108v108h-108z" />

    <!-- Lighter crimson highlight: top-right triangle, 30 % opacity -->
    <path
        android:fillColor="#EF5350"
        android:fillAlpha="0.30"
        android:pathData="M54,0 L108,0 L108,54 Z" />

    <!-- Dark vignette: bottom-left triangle, 20 % opacity -->
    <path
        android:fillColor="#7F0000"
        android:fillAlpha="0.20"
        android:pathData="M0,54 L0,108 L54,108 Z" />
</vector>
